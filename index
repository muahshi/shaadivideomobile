  <div class="s6-ring" style="width:360px;height:360px;top:50%;left:50%;margin:-180px 0 0 -180px;animation-delay:.3s"></div>
  <div class="s6-ring" style="width:220px;height:220px;top:50%;left:50%;margin:-110px 0 0 -110px;animation-delay:.5s"></div>

  <div class="s6-emoji">💍</div>
  <div class="s6-eyebrow fu">Aaj Se Shuru Karein</div>
  <div class="s6-title fu">Apni <em>Dream<br>Shaadi</em> Plan<br>Karein</div>
  <div class="s6-sub fu">100% Free • No Registration<br>Hindi & English Dono Mein</div>
