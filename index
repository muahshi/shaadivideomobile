<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Smart Shaadi AI — Mobile Ad</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --gold:#C9A84C;--gl:#E8C97A;--dk:#0D0B0E;--cr:#F5EFE0;--mu:#7A7068;--gr:#7ED3A0;
}

/* Fixed 390×844 — iPhone 14 Pro size */
html{width:390px;height:844px;overflow:hidden;background:#000;}
body{
  width:390px;height:844px;overflow:hidden;
  font-family:'DM Sans',sans-serif;color:var(--cr);
  background:var(--dk);position:relative;
}

/* ── STATUS BAR (fake) ── */
.status-bar{
  position:fixed;top:0;left:0;right:0;height:44px;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 20px;z-index:1000;
  background:linear-gradient(to bottom,rgba(13,11,14,1),rgba(13,11,14,0));
}
.sb-time{font-size:.75rem;font-weight:600;color:var(--cr);letter-spacing:.02em;}
.sb-icons{display:flex;align-items:center;gap:6px;}
.sb-icon{font-size:.65rem;color:var(--cr);}

/* ── PROGRESS BAR ── */
#progress-bar{
  position:fixed;top:44px;left:0;height:2px;width:0%;
  background:linear-gradient(90deg,var(--gold),var(--gl));
  z-index:999;
}

/* ── SCENE CONTAINER ── */
.scene{
  position:absolute;top:0;left:0;width:390px;height:844px;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  opacity:0;transform:translateY(28px);
  transition:opacity .6s ease,transform .6s ease;
  pointer-events:none;overflow:hidden;
}
.scene.active{opacity:1;transform:translateY(0);pointer-events:all;}
.scene.exit{opacity:0;transform:translateY(-28px);}

/* ── FADE-UP HELPER ── */
.fu{opacity:0;transform:translateY(16px);transition:opacity .55s ease,transform .55s ease;}
.scene.active .fu{opacity:1;transform:translateY(0);}
.scene.active .fu:nth-child(1){transition-delay:.1s}
.scene.active .fu:nth-child(2){transition-delay:.22s}
.scene.active .fu:nth-child(3){transition-delay:.34s}
.scene.active .fu:nth-child(4){transition-delay:.46s}
.scene.active .fu:nth-child(5){transition-delay:.58s}
.scene.active .fu:nth-child(6){transition-delay:.70s}
.scene.active .fu:nth-child(7){transition-delay:.82s}

/* ══════════════════════
   SCENE 1 — OPENER
══════════════════════ */
#s1{
  background:
    radial-gradient(ellipse 120% 60% at 50% 40%,rgba(201,168,76,.09) 0%,transparent 65%),
    var(--dk);
  text-align:center;padding:0 2rem;gap:0;
}
.s1-rings{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;pointer-events:none;opacity:.55;}
.particles{position:absolute;inset:0;pointer-events:none;overflow:hidden;}
.p{position:absolute;animation:rise linear infinite;}
@keyframes rise{
  0%{transform:translateY(900px);opacity:0}
  15%{opacity:.7}80%{opacity:.25}
  100%{transform:translateY(-60px);opacity:0}
}

.s1-logo-wrap{position:relative;z-index:2;margin-bottom:1.8rem;}
.s1-ring-icon{
  width:110px;height:110px;border-radius:50%;
  border:1.5px solid rgba(201,168,76,.25);
  display:flex;align-items:center;justify-content:center;
  margin:0 auto;font-size:3.2rem;
  background:radial-gradient(circle,rgba(201,168,76,.08),transparent 70%);
  animation:floatY 3s ease-in-out infinite;
  box-shadow:0 0 40px rgba(201,168,76,.12);
}
@keyframes floatY{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}

.s1-eyebrow{
  font-size:.62rem;letter-spacing:.22em;text-transform:uppercase;
  color:var(--gold);margin-bottom:.9rem;position:relative;z-index:2;
}
.s1-title{
  font-family:'Cormorant Garamond',serif;
  font-size:3.6rem;font-weight:300;line-height:1.05;
  position:relative;z-index:2;
}
.s1-title em{font-style:italic;color:var(--gl);}
.s1-sub{
  font-size:.82rem;color:rgba(245,239,224,.45);
  margin-top:1rem;position:relative;z-index:2;
  letter-spacing:.04em;line-height:1.6;
}
.s1-pill{
  display:inline-flex;align-items:center;gap:.45rem;
  background:rgba(201,168,76,.08);border:1px solid rgba(201,168,76,.22);
  padding:.28rem .85rem;border-radius:100px;
  font-size:.6rem;letter-spacing:.1em;text-transform:uppercase;color:var(--gl);
  margin-top:1.4rem;position:relative;z-index:2;
}
.pdot{width:5px;height:5px;border-radius:50%;background:var(--gr);animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.3;transform:scale(.7)}}

/* ══════════════════════
   SCENE 2 — PROBLEM
══════════════════════ */
#s2{
  background:
    radial-gradient(ellipse 100% 50% at 50% 90%,rgba(224,80,80,.04),transparent 60%),
    var(--dk);
  padding:5rem 1.6rem 2rem;justify-content:flex-start;text-align:left;
}
.s2-top{width:100%;margin-bottom:1.8rem;}
.s2-eyebrow{font-size:.6rem;letter-spacing:.18em;text-transform:uppercase;color:#e07070;margin-bottom:.8rem;}
.s2-title{font-family:'Cormorant Garamond',serif;font-size:2.5rem;font-weight:300;line-height:1.15;color:var(--cr);}
.s2-title span{font-style:italic;color:#e07070;}

.chaos-list{display:flex;flex-direction:column;gap:.75rem;width:100%;}
.chaos-item{
  display:flex;align-items:center;gap:.85rem;
  padding:.85rem 1rem;
  background:rgba(224,112,112,.05);border:1px solid rgba(224,112,112,.18);
  border-radius:10px;font-size:.82rem;color:rgba(245,239,224,.65);
  opacity:0;transform:translateX(-16px);
  transition:opacity .5s ease,transform .5s ease;
}
.scene.active .chaos-item:nth-child(1){opacity:1;transform:none;transition-delay:.2s}
.scene.active .chaos-item:nth-child(2){opacity:1;transform:none;transition-delay:.38s}
.scene.active .chaos-item:nth-child(3){opacity:1;transform:none;transition-delay:.56s}
.scene.active .chaos-item:nth-child(4){opacity:1;transform:none;transition-delay:.74s}
.cx{color:#e07070;font-size:1rem;font-weight:700;flex-shrink:0;}
.s2-emoji-bg{
  position:absolute;bottom:-30px;right:-20px;
  font-size:8rem;opacity:.06;pointer-events:none;
  animation:floatY 4s ease-in-out infinite;
}

/* ══════════════════════
   SCENE 3 — SOLUTION
══════════════════════ */
#s3{
  background:
    radial-gradient(ellipse 120% 50% at 50% 0%,rgba(201,168,76,.07),transparent 60%),
    var(--dk);
  padding:5rem 1.6rem 2rem;justify-content:flex-start;text-align:left;
}
.s3-eyebrow{font-size:.6rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);margin-bottom:.7rem;width:100%;}
.s3-title{font-family:'Cormorant Garamond',serif;font-size:2.6rem;font-weight:300;line-height:1.1;width:100%;margin-bottom:1.5rem;}
.s3-title em{font-style:italic;color:var(--gl);}

/* mini chat card */
.chat-card-m{
  width:100%;
  background:rgba(15,13,22,.98);border:1px solid rgba(201,168,76,.2);
  border-radius:14px;padding:1.1rem;
  box-shadow:0 20px 60px rgba(0,0,0,.6);margin-bottom:1.3rem;
}
.chat-hdr-m{display:flex;align-items:center;gap:.5rem;margin-bottom:1rem;font-size:.58rem;letter-spacing:.12em;text-transform:uppercase;color:var(--gold);}
.cdot{width:6px;height:6px;border-radius:50%;background:var(--gr);animation:pulse 2s infinite;flex-shrink:0;}
.chat-msg-m{border-radius:10px 10px 10px 2px;padding:.6rem .8rem;font-size:.75rem;line-height:1.5;margin-bottom:.45rem;}
.ai-m{background:rgba(201,168,76,.07);border:1px solid rgba(201,168,76,.12);color:rgba(245,239,224,.85);}
.u-m{background:rgba(245,239,224,.05);border:1px solid rgba(245,239,224,.07);border-radius:10px 10px 2px 10px;margin-left:1.2rem;color:rgba(245,239,224,.5);}
.ctag{font-size:.55rem;color:var(--gold);font-weight:500;margin-bottom:.15rem;}

.s3-feats{display:flex;flex-direction:column;gap:.6rem;width:100%;}
.s3-feat-m{
  display:flex;align-items:center;gap:.75rem;
  padding:.7rem .9rem;
  background:rgba(201,168,76,.04);border:1px solid rgba(201,168,76,.12);
  border-radius:8px;font-size:.78rem;color:rgba(245,239,224,.72);
}
.s3-feat-m b{color:var(--cr);font-weight:500;}
.s3fi{font-size:1rem;flex-shrink:0;}

/* ══════════════════════
   SCENE 4 — FEATURES
══════════════════════ */
#s4{
  background:var(--dk);
  padding:5rem 1.4rem 2rem;justify-content:flex-start;
}
.s4-eyebrow{font-size:.6rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);margin-bottom:.6rem;width:100%;}
.s4-title{font-family:'Cormorant Garamond',serif;font-size:2.2rem;font-weight:300;width:100%;margin-bottom:1.3rem;}
.s4-title em{font-style:italic;color:var(--gl);}
.feat-grid-m{display:grid;grid-template-columns:1fr 1fr;gap:.65rem;width:100%;}
.feat-card-m{
  background:rgba(201,168,76,.03);border:1px solid rgba(201,168,76,.1);
  border-radius:10px;padding:1rem .9rem;
  transition:border-color .3s,background .3s;
}
.feat-card-m.glow{border-color:rgba(201,168,76,.45);background:rgba(201,168,76,.08);}
.fci{font-size:1.4rem;margin-bottom:.5rem;}
.feat-card-m h3{font-family:'Cormorant Garamond',serif;font-size:.9rem;color:var(--cr);margin-bottom:.3rem;line-height:1.3;}
.feat-card-m p{font-size:.65rem;color:var(--mu);line-height:1.5;}
.fbadge{display:inline-block;font-size:.52rem;background:var(--gold);color:var(--dk);padding:.1rem .38rem;border-radius:100px;margin-top:.4rem;font-weight:700;letter-spacing:.04em;}

/* ══════════════════════
   SCENE 5 — STATS
══════════════════════ */
#s5{
  background:
    radial-gradient(ellipse 130% 60% at 50% 50%,rgba(201,168,76,.07),transparent 65%),
    var(--dk);
  padding:4rem 1.6rem 2rem;justify-content:center;text-align:center;
}
.s5-eyebrow{font-size:.6rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);margin-bottom:.7rem;}
.s5-title{font-family:'Cormorant Garamond',serif;font-size:2.3rem;font-weight:300;margin-bottom:2rem;}
.s5-title em{font-style:italic;color:var(--gl);}
.stats-grid-m{display:grid;grid-template-columns:1fr 1fr;gap:1rem;width:100%;margin-bottom:2rem;}
.stat-m{
  background:rgba(201,168,76,.04);border:1px solid rgba(201,168,76,.1);
  border-radius:12px;padding:1.2rem .8rem;text-align:center;
}
.snum-m{
  font-family:'Cormorant Garamond',serif;font-size:2.8rem;font-weight:600;
  color:var(--gl);line-height:1;
}
.slbl-m{font-size:.6rem;color:var(--mu);letter-spacing:.09em;text-transform:uppercase;margin-top:.35rem;}
.test-m{
  width:100%;
  background:rgba(201,168,76,.04);border:1px solid rgba(201,168,76,.13);
  border-radius:12px;padding:1.2rem 1.3rem;
  font-family:'Cormorant Garamond',serif;font-size:.88rem;font-style:italic;
  color:rgba(245,239,224,.72);line-height:1.65;text-align:left;
}
.test-stars{color:var(--gold);font-size:.75rem;margin-bottom:.5rem;letter-spacing:.04em;}
.test-author-m{font-family:'DM Sans',sans-serif;font-style:normal;font-size:.62rem;color:var(--gold);margin-top:.6rem;letter-spacing:.04em;}

/* ══════════════════════
   SCENE 6 — CTA
══════════════════════ */
#s6{
  background:
    radial-gradient(ellipse 130% 70% at 50% 40%,rgba(201,168,76,.1),transparent 60%),
    var(--dk);
  text-align:center;padding:0 2rem;
}
.s6-ring{position:absolute;border-radius:50%;border:1px solid rgba(201,168,76,.07);animation:expandRing 3s ease-out both;}
@keyframes expandRing{from{transform:scale(.4);opacity:.6}to{transform:scale(1);opacity:1}}
.s6-emoji{font-size:3rem;margin-bottom:1rem;animation:floatY 3s ease-in-out infinite;position:relative;z-index:2;}
.s6-eyebrow{font-size:.62rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);margin-bottom:.8rem;position:relative;z-index:2;}
.s6-title{
  font-family:'Cormorant Garamond',serif;font-size:3.2rem;font-weight:300;line-height:1.1;
  position:relative;z-index:2;
}
.s6-title em{font-style:italic;color:var(--gl);}
.s6-sub{font-size:.78rem;color:rgba(245,239,224,.45);margin:1rem 0 1.8rem;position:relative;z-index:2;line-height:1.7;}
.cta-btn-m{
  display:inline-block;background:var(--gold);color:var(--dk);
  padding:.95rem 2.2rem;border-radius:6px;font-size:.92rem;font-weight:500;
  letter-spacing:.05em;position:relative;z-index:2;
  animation:glowPulse 2s ease-in-out infinite;
}
@keyframes glowPulse{0%,100%{box-shadow:0 0 0 0 rgba(201,168,76,.4)}50%{box-shadow:0 0 28px 8px rgba(201,168,76,.2)}}
.s6-trust{
  display:flex;align-items:center;gap:.5rem;justify-content:center;
  background:rgba(126,211,160,.07);border:1px solid rgba(126,211,160,.2);
  padding:.4rem 1rem;border-radius:100px;font-size:.68rem;color:var(--gr);
  margin-top:1.1rem;position:relative;z-index:2;
}
.s6-url{font-size:.7rem;color:rgba(201,168,76,.45);margin-top:1rem;letter-spacing:.09em;position:relative;z-index:2;}

/* ── SCENE DOTS ── */
#scene-dots{
  position:fixed;bottom:28px;left:50%;transform:translateX(-50%);
  display:flex;gap:7px;z-index:999;
}
.dot{width:5px;height:5px;border-radius:50%;background:rgba(201,168,76,.25);transition:all .3s;}
.dot.active{background:var(--gold);width:18px;border-radius:3px;}

/* ── TIMER ── */
#timer{
  position:fixed;bottom:28px;right:20px;
  font-size:.65rem;color:rgba(201,168,76,.4);letter-spacing:.1em;z-index:999;
}

/* ── HOME INDICATOR ── */
.home-ind{
  position:fixed;bottom:8px;left:50%;transform:translateX(-50%);
  width:120px;height:4px;border-radius:2px;
  background:rgba(245,239,224,.2);z-index:1000;
}
</style>
</head>
