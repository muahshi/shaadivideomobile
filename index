    <div class="feat-card fade-up" id="fc6">
      <div class="feat-card-icon">📖</div>
      <h3>30+ Expert Articles</h3>
      <p>Catering, decor, jewellery guides</p>
      <div class="badge">FREE</div>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════
     SCENE 5 — SOCIAL PROOF (23–27s)
══════════════════════════════════════ -->
<div class="scene" id="s5">
  <div class="s5-eyebrow fade-up">Trusted by Real Couples</div>
  <div class="s5-title fade-up"><em>Results</em> Jo Bol Dete Hain</div>
  <div class="stats-row">
    <div class="stat-item fade-up">
      <div class="stat-num">2,400+</div>
      <div class="stat-lbl">Couples Helped</div>
