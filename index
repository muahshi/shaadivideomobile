</div>

<script>
// ── CLOCK ──
(function(){
  var d=new Date();
  var h=d.getHours()%12||12;
  var m=d.getMinutes();
  document.getElementById('clock').textContent=h+':'+(m<10?'0':'')+m;
})();

// ── PARTICLES ──
(function(){
  var c=document.getElementById('particles');
  var items=['♡','♥','💍','✨','⭐','♡'];
  for(var i=0;i<18;i++){
    var p=document.createElement('span');
    p.className='p';
    p.textContent=items[i%items.length];
    p.style.cssText=
      'left:'+Math.random()*100+'%;'+
      'bottom:-20px;'+
      'font-size:'+(0.5+Math.random()*.9)+'rem;'+
      'animation-duration:'+(9+Math.random()*10)+'s;'+
      'animation-delay:-'+(Math.random()*14)+'s;'+
      'opacity:'+(0.04+Math.random()*.07)+';'+
      'position:absolute;';
    c.appendChild(p);
  }
})();

// ── SCENE ENGINE ──
var TOTAL=30;
var scenes=['s1','s2','s3','s4','s5','s6'];
var timings=[0,5,11,18,23,27];
var startTime=Date.now();
var currentScene=0;

function activateScene(idx){
  if(idx===currentScene && document.getElementById(scenes[idx]).classList.contains('active')) return;

  var prev=document.getElementById(scenes[currentScene]);
  prev.classList.remove('active');
  prev.classList.add('exit');
  setTimeout(function(){prev.classList.remove('exit');},650);

  document.querySelectorAll('.dot').forEach(function(d,i){d.classList.toggle('active',i===idx);});

  var next=document.getElementById(scenes[idx]);
  next.classList.add('active');
  currentScene=idx;

  // Feature cards glow animation
  if(idx===3){
    var cards=document.querySelectorAll('.feat-card-m');
    cards.forEach(function(c){c.classList.remove('glow');});
    var g=0;
    var iv=setInterval(function(){
      cards.forEach(function(c){c.classList.remove('glow');});
      if(g<cards.length){cards[g].classList.add('glow');g++;}
      else clearInterval(iv);
    },750);
  }
}

function tick(){
  var elapsed=(Date.now()-startTime)/1000;
  var pct=Math.min(elapsed/TOTAL*100,100);
  document.getElementById('progress-bar').style.width=pct+'%';

  var remaining=Math.max(0,Math.ceil(TOTAL-elapsed));
  var m=Math.floor(remaining/60);
  var s=remaining%60;
  document.getElementById('timer').textContent=m+':'+(s<10?'0':'')+s;

  for(var i=timings.length-1;i>=0;i--){
    if(elapsed>=timings[i]){
      if(i!==currentScene) activateScene(i);
      break;
    }
  }

  if(elapsed<TOTAL+0.5){
    requestAnimationFrame(tick);
  } else {
    // Loop
    startTime=Date.now();
    currentScene=0;
    document.querySelectorAll('.scene').forEach(function(sc){sc.classList.remove('active','exit');});
    document.getElementById('s1').classList.add('active');
    document.querySelectorAll('.dot').forEach(function(d,i){d.classList.toggle('active',i===0);});
    requestAnimationFrame(tick);
  }
}

requestAnimationFrame(tick);
</script>
