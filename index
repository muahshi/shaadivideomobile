    </div>
    <div class="feat-card fade-up" id="fc5">
      <div class="feat-card-icon">🤝</div>
      <h3>Vendor Negotiation Bot</h3>
      <p>AI se vendors se deal karein</p>
      <div class="badge">FREE</div>
