<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Smart Shaadi AI — Advertisement</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
  :root{
    --gold:#C9A84C;--gl:#E8C97A;--dk:#0D0B0E;--cr:#F5EFE0;--mu:#7A7068;--gr:#7ED3A0;
  }
  html,body{width:1280px;height:720px;overflow:hidden;background:var(--dk);}
  body{font-family:'DM Sans',sans-serif;color:var(--cr);position:relative;}

  /* ── PROGRESS BAR ── */
  #progress-bar{
    position:fixed;top:0;left:0;height:3px;width:0%;
    background:linear-gradient(90deg,var(--gold),var(--gl));
    z-index:999;transition:width linear;
  }

  /* ── SCENE CONTAINER ── */
  .scene{
    position:absolute;top:0;left:0;width:1280px;height:720px;
    display:flex;align-items:center;justify-content:center;
    opacity:0;transform:translateY(30px);
    transition:opacity .7s ease,transform .7s ease;
    pointer-events:none;
  }
  .scene.active{opacity:1;transform:translateY(0);pointer-events:all;}
  .scene.exit{opacity:0;transform:translateY(-30px);}

  /* ── SCENE 1 — CINEMATIC OPENER ── */
  #s1{
    background:radial-gradient(ellipse 80% 70% at 50% 50%,rgba(201,168,76,.07) 0%,transparent 70%),var(--dk);
    flex-direction:column;text-align:center;gap:0;
  }
  .s1-rings{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;pointer-events:none;}
  .s1-rings svg{opacity:.5}
  .s1-emoji{font-size:4rem;margin-bottom:1.5rem;animation:float 3s ease-in-out infinite;position:relative;z-index:2;}
  @keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-12px)}}
  .s1-eyebrow{font-size:.75rem;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);margin-bottom:1.2rem;position:relative;z-index:2;}
  .s1-title{font-family:'Cormorant Garamond',serif;font-size:5.5rem;font-weight:300;line-height:1;position:relative;z-index:2;}
  .s1-title em{font-style:italic;color:var(--gl);}
  .s1-sub{font-size:1.1rem;color:rgba(245,239,224,.5);margin-top:1.2rem;position:relative;z-index:2;letter-spacing:.04em;}

  /* Particles */
  .particles{position:absolute;inset:0;pointer-events:none;overflow:hidden;}
  .p{position:absolute;border-radius:50%;animation:rise linear infinite;}
  @keyframes rise{0%{transform:translateY(100%);opacity:0}20%{opacity:.6}80%{opacity:.3}100%{transform:translateY(-120px);opacity:0}}

  /* ── SCENE 2 — PROBLEM ── */
  #s2{
    background:var(--dk);
    flex-direction:row;gap:0;
  }
  .s2-left{width:50%;padding:5rem;display:flex;flex-direction:column;justify-content:center;}
  .s2-right{width:50%;position:relative;overflow:hidden;}
  .s2-bg{
    position:absolute;inset:0;
    background:linear-gradient(135deg,#1a0a10 0%,#0d0b0e 60%);
    display:flex;align-items:center;justify-content:center;font-size:8rem;opacity:.4;
  }
  .chaos-list{display:flex;flex-direction:column;gap:1.1rem;margin-top:1.8rem;}
  .chaos-item{
    display:flex;align-items:center;gap:1rem;padding:1rem 1.3rem;
    background:rgba(224,112,112,.06);border:1px solid rgba(224,112,112,.2);
    border-radius:8px;font-size:.9rem;color:rgba(245,239,224,.65);
    animation:shakeIn .5s ease both;
  }
  @keyframes shakeIn{from{opacity:0;transform:translateX(-20px)}to{opacity:1;transform:translateX(0)}}
  .chaos-x{color:#e07070;font-size:1.1rem;font-weight:700;flex-shrink:0;}
  .s2-eyebrow{font-size:.65rem;letter-spacing:.18em;text-transform:uppercase;color:#e07070;margin-bottom:.9rem;}
  .s2-title{font-family:'Cormorant Garamond',serif;font-size:3.2rem;font-weight:300;line-height:1.15;}
  .s2-sub{font-size:.88rem;color:var(--mu);margin-top:1rem;line-height:1.7;}

  /* ── SCENE 3 — SOLUTION REVEAL ── */
  #s3{
    background:radial-gradient(ellipse 60% 80% at 30% 50%,rgba(201,168,76,.05),transparent 70%),var(--dk);
    flex-direction:row;
  }
  .s3-left{width:52%;padding:5rem;display:flex;flex-direction:column;justify-content:center;}
  .s3-right{width:48%;display:flex;align-items:center;justify-content:center;padding:3rem;}
  .s3-eyebrow{font-size:.65rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);margin-bottom:.9rem;}
  .s3-title{font-family:'Cormorant Garamond',serif;font-size:3.5rem;font-weight:300;line-height:1.1;}
  .s3-title em{font-style:italic;color:var(--gl);}
  .s3-features{display:flex;flex-direction:column;gap:.8rem;margin-top:1.8rem;}
  .s3-feat{
    display:flex;align-items:center;gap:.9rem;padding:.85rem 1.1rem;
    background:rgba(201,168,76,.05);border:1px solid rgba(201,168,76,.15);
    border-radius:8px;
  }
  .s3-feat-icon{font-size:1.2rem;flex-shrink:0;}
  .s3-feat-text{font-size:.85rem;color:rgba(245,239,224,.75);}
  .s3-feat-text b{color:var(--cr);font-weight:500;}

  /* Chat card */
  .chat-card{
    background:rgba(15,13,22,.98);border:1px solid rgba(201,168,76,.2);
    border-radius:16px;padding:1.5rem;width:320px;
    box-shadow:0 30px 80px rgba(0,0,0,.7),0 0 0 1px rgba(201,168,76,.05);
  }
  .chat-hdr{display:flex;align-items:center;gap:.6rem;margin-bottom:1.2rem;font-size:.65rem;letter-spacing:.12em;text-transform:uppercase;color:var(--gold);}
  .cdot{width:7px;height:7px;border-radius:50%;background:var(--gr);animation:pulse2 2s infinite;}
  @keyframes pulse2{0%,100%{opacity:1}50%{opacity:.3}}
  .chat-msg{border-radius:10px 10px 10px 2px;padding:.7rem .9rem;font-size:.8rem;line-height:1.55;margin-bottom:.55rem;}
  .ai-msg{background:rgba(201,168,76,.07);border:1px solid rgba(201,168,76,.12);color:rgba(245,239,224,.85);}
  .u-msg{background:rgba(245,239,224,.05);border:1px solid rgba(245,239,224,.07);border-radius:10px 10px 2px 10px;margin-left:1.5rem;color:rgba(245,239,224,.55);}
  .chat-tag{font-size:.6rem;color:var(--gold);font-weight:500;margin-bottom:.2rem;}

  /* ── SCENE 4 — FEATURES GRID ── */
  #s4{
    background:var(--dk);flex-direction:column;padding:4rem 5rem;
    align-items:flex-start;justify-content:center;
  }
  .s4-eyebrow{font-size:.65rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);margin-bottom:.7rem;}
  .s4-title{font-family:'Cormorant Garamond',serif;font-size:2.8rem;font-weight:300;margin-bottom:2rem;}
  .s4-title em{font-style:italic;color:var(--gl);}
  .feat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.1rem;width:100%;}
  .feat-card{
    background:rgba(201,168,76,.03);border:1px solid rgba(201,168,76,.1);
    border-radius:12px;padding:1.4rem;
    transition:border-color .3s,background .3s;
  }
  .feat-card.glow{border-color:rgba(201,168,76,.4);background:rgba(201,168,76,.07);}
  .feat-card-icon{font-size:1.8rem;margin-bottom:.8rem;}
  .feat-card h3{font-family:'Cormorant Garamond',serif;font-size:1.1rem;color:var(--cr);margin-bottom:.4rem;}
  .feat-card p{font-size:.75rem;color:var(--mu);line-height:1.6;}
  .feat-card .badge{display:inline-block;font-size:.6rem;background:var(--gold);color:var(--dk);padding:.12rem .45rem;border-radius:100px;margin-top:.5rem;font-weight:600;}

  /* ── SCENE 5 — STATS ── */
  #s5{
    background:radial-gradient(ellipse 70% 80% at 50% 50%,rgba(201,168,76,.06),transparent 65%),var(--dk);
    flex-direction:column;text-align:center;gap:0;padding:4rem;
  }
  .s5-eyebrow{font-size:.65rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);margin-bottom:.9rem;}
  .s5-title{font-family:'Cormorant Garamond',serif;font-size:3rem;font-weight:300;margin-bottom:3rem;}
  .s5-title em{font-style:italic;color:var(--gl);}
  .stats-row{display:flex;justify-content:center;gap:4rem;margin-bottom:3rem;}
  .stat-item{text-align:center;}
  .stat-num{
    font-family:'Cormorant Garamond',serif;font-size:4.5rem;font-weight:600;
    color:var(--gl);line-height:1;
    animation:countUp .8s ease both;
  }
  @keyframes countUp{from{opacity:0;transform:scale(.7)}to{opacity:1;transform:scale(1)}}
  .stat-lbl{font-size:.72rem;color:var(--mu);letter-spacing:.1em;text-transform:uppercase;margin-top:.4rem;}
  .testimonial-mini{
    max-width:520px;margin:0 auto;
    background:rgba(201,168,76,.05);border:1px solid rgba(201,168,76,.15);
    border-radius:12px;padding:1.4rem 1.8rem;
    font-family:'Cormorant Garamond',serif;font-size:1.05rem;font-style:italic;
    color:rgba(245,239,224,.75);line-height:1.65;
  }
  .test-author{font-family:'DM Sans',sans-serif;font-style:normal;font-size:.72rem;color:var(--gold);margin-top:.7rem;letter-spacing:.05em;}

  /* ── SCENE 6 — CTA ── */
  #s6{
    background:
      radial-gradient(ellipse 80% 60% at 50% 40%,rgba(201,168,76,.1),transparent 60%),
      var(--dk);
    flex-direction:column;text-align:center;gap:0;
  }
  .s6-ring{position:absolute;border-radius:50%;border:1px solid rgba(201,168,76,.08);animation:expandRing 3s ease-out both;}
  @keyframes expandRing{from{transform:scale(.5);opacity:.5}to{transform:scale(1);opacity:1}}
  .s6-emoji{font-size:3.5rem;margin-bottom:1.2rem;position:relative;z-index:2;animation:float 3s ease-in-out infinite;}
  .s6-eyebrow{font-size:.65rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);margin-bottom:.9rem;position:relative;z-index:2;}
  .s6-title{font-family:'Cormorant Garamond',serif;font-size:4.5rem;font-weight:300;line-height:1.1;position:relative;z-index:2;}
  .s6-title em{font-style:italic;color:var(--gl);}
  .s6-sub{font-size:.95rem;color:rgba(245,239,224,.5);margin:1.1rem 0 2.2rem;position:relative;z-index:2;}
  .cta-btn{
    display:inline-block;background:var(--gold);color:var(--dk);
    padding:1rem 2.8rem;border-radius:4px;font-size:1rem;font-weight:500;
    letter-spacing:.05em;position:relative;z-index:2;
    animation:glow-pulse 2s ease-in-out infinite;
  }
  @keyframes glow-pulse{0%,100%{box-shadow:0 0 0 0 rgba(201,168,76,.4)}50%{box-shadow:0 0 30px 8px rgba(201,168,76,.25)}}
  .s6-url{font-size:.8rem;color:rgba(201,168,76,.5);margin-top:1.5rem;letter-spacing:.08em;position:relative;z-index:2;}
  .s6-free{
    display:inline-flex;align-items:center;gap:.5rem;
    background:rgba(126,211,160,.08);border:1px solid rgba(126,211,160,.25);
    padding:.35rem 1rem;border-radius:100px;font-size:.72rem;color:var(--gr);
    margin-top:1.1rem;position:relative;z-index:2;
  }

  /* ── SCENE INDICATOR ── */
  #scene-dots{
    position:fixed;bottom:24px;left:50%;transform:translateX(-50%);
    display:flex;gap:8px;z-index:999;
  }
  .dot{width:6px;height:6px;border-radius:50%;background:rgba(201,168,76,.3);transition:all .3s;}
  .dot.active{background:var(--gold);width:22px;border-radius:4px;}

  /* ── TIMER ── */
  #timer{
    position:fixed;bottom:24px;right:30px;
    font-size:.7rem;color:rgba(201,168,76,.4);letter-spacing:.1em;z-index:999;
    font-family:'DM Sans',sans-serif;
  }

  /* ── GLOBAL ENTRANCE ANIMATION HELPERS ── */
  .fade-up{opacity:0;transform:translateY(20px);transition:opacity .6s ease,transform .6s ease;}
  .scene.active .fade-up{opacity:1;transform:translateY(0);}
  .scene.active .fade-up:nth-child(1){transition-delay:.1s}
  .scene.active .fade-up:nth-child(2){transition-delay:.25s}
  .scene.active .fade-up:nth-child(3){transition-delay:.4s}
  .scene.active .fade-up:nth-child(4){transition-delay:.55s}
  .scene.active .fade-up:nth-child(5){transition-delay:.7s}
  .scene.active .fade-up:nth-child(6){transition-delay:.85s}

  /* stagger override for lists */
  .chaos-item:nth-child(1){animation-delay:.15s}
  .chaos-item:nth-child(2){animation-delay:.3s}
  .chaos-item:nth-child(3){animation-delay:.45s}
  .chaos-item:nth-child(4){animation-delay:.6s}

  .s3-feat:nth-child(1){animation-delay:.1s}
  .s3-feat:nth-child(2){animation-delay:.25s}
  .s3-feat:nth-child(3){animation-delay:.4s}
  .s3-feat:nth-child(4){animation-delay:.55s}
</style>
</head>
<body>

<!-- PROGRESS BAR -->
<div id="progress-bar"></div>

<!-- SCENE DOTS -->
<div id="scene-dots">
  <div class="dot active" id="dot-0"></div>
  <div class="dot" id="dot-1"></div>
  <div class="dot" id="dot-2"></div>
  <div class="dot" id="dot-3"></div>
  <div class="dot" id="dot-4"></div>
  <div class="dot" id="dot-5"></div>
</div>

<!-- TIMER -->
<div id="timer">0:30</div>

<!-- ══════════════════════════════════════
     SCENE 1 — OPENING HOOK (0–5s)
══════════════════════════════════════ -->
<div class="scene active" id="s1">
  <div class="particles" id="particles"></div>
  <div class="s1-rings">
    <svg width="700" height="700" viewBox="0 0 700 700">
      <circle cx="350" cy="350" r="320" fill="none" stroke="rgba(201,168,76,.05)" stroke-width="1"/>
      <circle cx="350" cy="350" r="250" fill="none" stroke="rgba(201,168,76,.04)" stroke-width="0.7"/>
      <circle cx="350" cy="350" r="180" fill="none" stroke="rgba(201,168,76,.06)" stroke-width="0.5"/>
      <circle cx="350" cy="350" r="340" fill="none" stroke="rgba(201,168,76,.03)" stroke-width="0.4"/>
    </svg>
  </div>
  <div class="s1-emoji fade-up">💍</div>
  <div class="s1-eyebrow fade-up">Introducing</div>
  <div class="s1-title fade-up">Smart<em>Shaadi</em> AI</div>
  <div class="s1-sub fade-up">India ka #1 AI Wedding Planner — Bilkul Free</div>
</div>

<!-- ══════════════════════════════════════
     SCENE 2 — PROBLEM (5–11s)
══════════════════════════════════════ -->
<div class="scene" id="s2">
  <div class="s2-left">
    <div class="s2-eyebrow fade-up">Shaadi Planning Mein Yeh Problems?</div>
    <div class="s2-title fade-up">Planning karna<br><em style="font-family:'Cormorant Garamond',serif;font-style:italic;color:#e07070">stress</em> ban gaya?</div>
    <div class="chaos-list">
      <div class="chaos-item"><span class="chaos-x">✗</span> Budget exceed ho jaata hai baar baar</div>
      <div class="chaos-item"><span class="chaos-x">✗</span> Guest list manage karna nightmare hai</div>
      <div class="chaos-item"><span class="chaos-x">✗</span> Venue compare karna time-consuming hai</div>
      <div class="chaos-item"><span class="chaos-x">✗</span> Koi ek jagah plan nahi hota</div>
    </div>
  </div>
  <div class="s2-right">
    <div class="s2-bg">😰</div>
  </div>
</div>

<!-- ══════════════════════════════════════
     SCENE 3 — SOLUTION (11–18s)
══════════════════════════════════════ -->
<div class="scene" id="s3">
  <div class="s3-left">
    <div class="s3-eyebrow fade-up">The Solution</div>
    <div class="s3-title fade-up">Sab Kuch <em>AI ke</em><br>Haath Mein Do</div>
    <div class="s3-features">
      <div class="s3-feat fade-up">
        <span class="s3-feat-icon">💰</span>
        <div class="s3-feat-text"><b>Budget Planner</b> — Auto category split, 20% savings</div>
      </div>
      <div class="s3-feat fade-up">
        <span class="s3-feat-icon">👥</span>
        <div class="s3-feat-text"><b>Guest Manager</b> — RSVP track, catering auto-calculate</div>
      </div>
      <div class="s3-feat fade-up">
        <span class="s3-feat-icon">🏛️</span>
        <div class="s3-feat-text"><b>Venue Comparison</b> — Best value auto-highlight</div>
      </div>
      <div class="s3-feat fade-up">
        <span class="s3-feat-icon">🤖</span>
        <div class="s3-feat-text"><b>AI Chatbot</b> — Hindi/English mein 24/7 help</div>
      </div>
    </div>
  </div>
  <div class="s3-right">
    <div class="chat-card">
      <div class="chat-hdr"><div class="cdot"></div> Smart Shaadi AI — Live</div>
      <div class="chat-msg ai-msg">
        <div class="chat-tag">AI Assistant</div>
        Aapke ₹25L budget mein 3 premium Delhi venues shortlist kar diye! November perfect rahega. 🎉
      </div>
      <div class="chat-msg u-msg">
        Delhi outdoor, November mein chahiye.
      </div>
      <div class="chat-msg ai-msg">
        <div class="chat-tag">AI Assistant</div>
        Caterers, photographer aur decor estimate — sab ready! ✨
      </div>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════
     SCENE 4 — FEATURES (18–23s)
══════════════════════════════════════ -->
<div class="scene" id="s4">
  <div class="s4-eyebrow fade-up">Free Tools — No Registration Needed</div>
  <div class="s4-title fade-up"><em>6 Powerful Tools,</em> Ek Jagah</div>
  <div class="feat-grid">
    <div class="feat-card fade-up" id="fc1">
      <div class="feat-card-icon">🧮</div>
