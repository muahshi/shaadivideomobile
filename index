      <div class="stat-num">4.9★</div>
      <div class="stat-lbl">Overall Rating</div>
    </div>
    <div class="stat-item fade-up">
      <div class="stat-num">24/7</div>
      <div class="stat-lbl">AI Support</div>
    </div>
  </div>
  <div class="testimonial-mini fade-up">
    "Smart Shaadi ne hamari Jaipur destination wedding plan karne mein itni madad ki — budget mein tha, sab perfect tha!"
    <div class="test-author">— Priya & Rahul Sharma, Jaipur Destination Wedding 2025</div>
  </div>
</div>

<!-- ══════════════════════════════════════
     SCENE 6 — CTA (27–30s)
══════════════════════════════════════ -->
<div class="scene" id="s6">
  <!-- Decorative rings -->
  <div class="s6-ring" style="width:600px;height:600px;top:50%;left:50%;margin:-300px 0 0 -300px;animation-delay:.1s"></div>
  <div class="s6-ring" style="width:450px;height:450px;top:50%;left:50%;margin:-225px 0 0 -225px;animation-delay:.3s"></div>
  <div class="s6-ring" style="width:300px;height:300px;top:50%;left:50%;margin:-150px 0 0 -150px;animation-delay:.5s"></div>

  <div class="s6-emoji">💍</div>
  <div class="s6-eyebrow fade-up">Aaj Se Shuru Karein</div>
  <div class="s6-title fade-up">Apni <em>Dream Shaadi</em><br>Plan Karein</div>
  <div class="s6-sub fade-up">100% Free • Koi Registration Nahi • Hindi & English</div>
  <a class="cta-btn fade-up" href="#">✨ smartshaadi.online</a>
  <div class="s6-free fade-up">
    <span style="width:7px;height:7px;border-radius:50%;background:var(--gr);display:inline-block;animation:pulse2 2s infinite"></span>
    Bilkul Free — Always
  </div>
  <div class="s6-url fade-up">🌐 smartshaadi.online</div>
</div>

<script>
  // ── PARTICLES (Scene 1) ──
  (function(){
    var c=document.getElementById('particles');
    var items=['♡','♥','💍','✨','⭐'];
    for(var i=0;i<20;i++){
      var p=document.createElement('span');
      p.className='p';
      p.textContent=items[i%items.length];
      p.style.cssText=
        'left:'+Math.random()*100+'%;'+
        'bottom:-30px;'+
        'font-size:'+(0.6+Math.random()*1.2)+'rem;'+
        'animation-duration:'+(10+Math.random()*12)+'s;'+
        'animation-delay:-'+(Math.random()*15)+'s;'+
        'opacity:'+(0.04+Math.random()*0.08)+';';
      c.appendChild(p);
    }
  })();

  // ── SCENE TIMINGS (seconds) ──
  // Scene durations: s1=5s, s2=6s, s3=7s, s4=5s, s5=4s, s6=3s = 30s total
  var TOTAL = 30;
  var scenes = ['s1','s2','s3','s4','s5','s6'];
  var timings = [0, 5, 11, 18, 23, 27]; // start times

  var startTime = Date.now();
  var currentScene = 0;

  function activateScene(idx){
    if(idx === currentScene && document.getElementById(scenes[idx]).classList.contains('active')) return;
    // Exit current
    var prev = document.getElementById(scenes[currentScene]);
    prev.classList.remove('active');
    prev.classList.add('exit');
    setTimeout(function(){ prev.classList.remove('exit'); }, 700);

    // Update dots
    document.querySelectorAll('.dot').forEach(function(d,i){
      d.classList.toggle('active', i===idx);
    });

    // Enter new
    var next = document.getElementById(scenes[idx]);
    next.classList.add('active');
    currentScene = idx;

    // Scene 4: animate feature cards sequentially
    if(idx===3){
      var cards = document.querySelectorAll('.feat-card');
      cards.forEach(function(c){ c.classList.remove('glow'); });
      var g=0;
      var glowInterval = setInterval(function(){
        cards.forEach(function(c){ c.classList.remove('glow'); });
        if(g < cards.length){ cards[g].classList.add('glow'); g++; }
        else{ clearInterval(glowInterval); }
      }, 800);
    }
  }

  function tick(){
    var elapsed = (Date.now() - startTime) / 1000;
    var pct = Math.min(elapsed / TOTAL * 100, 100);
    document.getElementById('progress-bar').style.width = pct + '%';

    // Timer countdown
    var remaining = Math.max(0, Math.ceil(TOTAL - elapsed));
    var m = Math.floor(remaining/60);
    var s = remaining % 60;
    document.getElementById('timer').textContent = m+':'+(s<10?'0':'')+s;

    // Scene switching
    for(var i = timings.length-1; i>=0; i--){
      if(elapsed >= timings[i]){
        if(i !== currentScene) activateScene(i);
        break;
      }
    }

    if(elapsed < TOTAL + 0.5){
      requestAnimationFrame(tick);
    } else {
      // Loop
      startTime = Date.now();
      currentScene = 0;
      document.querySelectorAll('.scene').forEach(function(s){ s.classList.remove('active','exit'); });
      document.getElementById('s1').classList.add('active');
      document.querySelectorAll('.dot').forEach(function(d,i){ d.classList.toggle('active',i===0); });
      requestAnimationFrame(tick);
    }
  }

  requestAnimationFrame(tick);
</script>
</body>
</html>
